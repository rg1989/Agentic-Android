            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="9"
            android:strokeLineCap="round"
            android:pathData="M89,56 L79,34 M155,56 L165,34 M188,132 C204,168 186,188 156,182" />
        <!-- head dome with eye holes -->
        <path
            android:fillColor="#FFFFFFFF"
            android:fillType="evenOdd"
            android:pathData="M68,98 A56,56 0 0 1 176,98 Z M94,80 a7,7 0 1 0 14,0 a7,7 0 1 0 -14,0 Z M136,80 a7,7 0 1 0 14,0 a7,7 0 1 0 -14,0 Z" />
