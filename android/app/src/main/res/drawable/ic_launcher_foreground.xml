            android:pathData="M56,112 a7,7 0 0 1 7,7 v32 a7,7 0 0 1 -14,0 v-32 a7,7 0 0 1 7,-7 Z" />
        <path android:fillColor="#FFFFFFFF"
            android:pathData="M188,112 a7,7 0 0 1 7,7 v32 a7,7 0 0 1 -14,0 v-32 a7,7 0 0 1 7,-7 Z" />
        <!-- speech-bubble tail -->
