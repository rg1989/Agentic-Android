        <path android:fillColor="#FFFFFFFF"
            android:pathData="M84,106 h76 a16,16 0 0 1 16,16 v30 a16,16 0 0 1 -16,16 h-76 a16,16 0 0 1 -16,-16 v-30 a16,16 0 0 1 16,-16 Z" />
