{
  "name": "agentic-android-backbone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Universal two-way bus connecting any agent to an Android phone: protocol + E2E crypto + relay + bridge (MCP).",
  "scripts": {
    "test": "tsx --test test/*.test.ts",
    "relay": "tsx src/relay.ts",
    "bridge": "tsx src/bridge.ts",
    "hub": "tsx src/panel.ts",
    "panel": "tsx src/panel.ts",
    "agent": "tsx src/agent.ts",
    "agent:claude": "tsx src/agent-cli.ts",
    "mcp:phone": "tsx src/phone-mcp.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "libsodium-wrappers": "^0.7.15",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
